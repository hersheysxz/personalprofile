NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/rachel-portfolio?retryWrites=true&w=majority

# Comma-separated frontend URLs for CORS.
# For production, use your Vercel domain, for example:
# FRONTEND_URL=https://your-portfolio.vercel.app
FRONTEND_URL=http://localhost:5500

# Admin endpoints
ADMIN_KEY=replace-with-a-long-random-secret

# Email recipient
ADMIN_EMAIL=rachelregacho645@gmail.com

# Gmail mailer. Use a Google App Password, not your regular password.
EMAIL_PROVIDER=gmail
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-16-character-google-app-password
EMAIL_FROM=Rachel Portfolio <your-gmail-address@gmail.com>

# SendGrid alternative
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Rachel Portfolio <verified-sender@example.com>

# Custom SMTP alternative
# EMAIL_PROVIDER=custom
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=Rachel Portfolio <verified-sender@example.com>
